# Supabase — get from Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Comma-separated list of admin email addresses. Anyone NOT on this list is
# rejected by the proxy even with a valid Supabase Auth account.
# Example: ADMIN_ALLOWLIST=charlotte@switchleads.co.uk,sasha@switchleads.co.uk
ADMIN_ALLOWLIST=
