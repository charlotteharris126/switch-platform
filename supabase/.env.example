# Switchable Ltd — Platform environment variables (EXAMPLE / TEMPLATE)
#
# This file documents the shape only. It contains NO real values.
# Copy it to a local path OUTSIDE iCloud on each device, then fill from LastPass:
#
#   mkdir -p ~/Switchable/platform
#   cp "<path-to-switch-claude>/platform/supabase/.env.example" ~/Switchable/platform/.env
#   open ~/Switchable/platform/.env   # paste values from LastPass folder "Supabase — Switchable Ltd"
#
# NEVER commit real values back into this file or into any iCloud-synced path.
# See .claude/rules/data-infrastructure.md §5 (Secrets management).

# Supabase project
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# DB connection via Session Pooler (IPv4-compatible). Direct `db.<ref>.supabase.co` is IPv6-only
# on new projects and unreachable from most dev machines — use the pooler instead.
# Format: postgresql://<role>.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Role for this URL = postgres (superuser). For scoped roles (readonly_analytics / n8n_writer / ads_ingest)
# the format is identical, just swap role name + password.
SUPABASE_DB_URL=postgresql://postgres.xxxxxxxxxxxx:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Scoped role passwords (generated via: openssl rand -base64 32)
SUPABASE_READONLY_ANALYTICS_PASSWORD=
SUPABASE_FUNCTIONS_WRITER_PASSWORD=
SUPABASE_ADS_INGEST_PASSWORD=
