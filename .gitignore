# OS / editor artefacts
.DS_Store
*.swp
*.swo
.vscode/

# iCloud placeholder files
*.icloud

# Real secrets — defensive global rule. .env.example files are tracked
# (they contain placeholder values only — see file headers).
.env
.env.local
.env.*.local

# App-level ignores live in app/.gitignore (Next.js build output, etc.)

# Supabase CLI local state
supabase/.temp/
supabase/.branches/

# Edge Function build artefacts
supabase/functions/_shared/dist/
